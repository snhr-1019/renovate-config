{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "timezone": "Asia/Tokyo",
  "schedule": "before 6am on the 1st day of the month",
  "reviewers": [
    "@snhr-1019"
  ],
  "labels": [
    "dependencies"
  ],
  "pre-commit": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["\\.chezmoiexternal\\.toml$"],
      "matchStrings": [
        "url\\s*=\\s*\"https://github\\.com/(?<depName>[^/]+/[^/]+)/releases/download/v?(?<currentValue>[\\d.]+)/[^\"]*\""
      ],
      "extractVersionTemplate": "^v?(?<version>.+)$",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "matchPackagePatterns": ["*"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "dependencies non-major"
    },
    {
      "matchDepNames": ["java"],
      "groupName": "java"
    },
    {
      "matchDepNames": ["node"],
      "groupName": "node"
    },
    {
      "matchDepNames": ["python"],
      "groupName": "python"
    }
  ]
}
